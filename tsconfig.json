{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ESNext",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "paths": {
      "~account/*": ["./src/modules/account/*"],
      "~landing/*": ["./src/modules/landing/*"],
      "~player/*": ["./src/modules/player/*"],
      "~auth/*": ["./src/modules/auth/*"],
      "~analytics/*": ["./src/modules/analytics/*"],
      "@/*": ["./src/*"]
    }
  }
}
